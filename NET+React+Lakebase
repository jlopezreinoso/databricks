def _parsear_fecha_corte(fecha_corte: str) -> datetime:
    """
    Parsea la fecha_corte recibida desde el widget de Databricks.
    Acepta: 'YYYY-MM-DD', 'YYYY/MM/DD', 'DD-MM-YYYY', 'DD/MM/YYYY'.
    """
    fecha_corte = (fecha_corte or "").strip()
    if not fecha_corte:
        raise ValueError(
            "El parámetro 'fecha_corte' está vacío. "
            "Verifica que el widget 'fechaCorte' tenga un valor antes de ejecutar."
        )
    for fmt in ("%Y-%m-%d", "%Y/%m/%d", "%d-%m-%Y", "%d/%m/%Y"):
        try:
            return datetime.strptime(fecha_corte, fmt)
        except ValueError:
            continue
    raise ValueError(
        f"Formato de fecha_corte no reconocido: '{fecha_corte}'. "
        "Formatos válidos: YYYY-MM-DD, YYYY/MM/DD, DD-MM-YYYY, DD/MM/YYYY."
    )


def _derivar_valor_corte(dt: datetime, formato: str) -> Any:
    """
    Convierte un datetime al valor de corte requerido por la tabla fuente
    según el formato declarado.
    """
    if formato in FORMATOS_CORTE:
        return FORMATOS_CORTE[formato](dt)
    formato_lower = formato.lower()
    for clave, fn in FORMATOS_CORTE.items():
        if clave.lower() == formato_lower:
            return fn(dt)
    try:
        return dt.strftime(formato)
    except Exception:
        raise ValueError(
            f"formato_corte_fuente '{formato}' no reconocido. "
            f"Formatos disponibles: {list(FORMATOS_CORTE.keys())} "
            "o cualquier patrón strftime válido (ej: '%Y%m')."
        )


