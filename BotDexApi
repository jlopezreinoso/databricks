# Celda 11: Exportar a Pandas

def to_pandas():
    tok_path, _ = get_paths()
    if USE_UNITY_CATALOG:
        df = spark.table(UC_TABLE_TOKENS)
    else:
        df = spark.read.format("delta").load(tok_path)
    pdf = df.toPandas()
    pdf["links"]       = pdf["links_json"].apply(lambda x: json.loads(x) if x else [])
    pdf["link_count"]  = pdf["links"].apply(len)
    pdf["has_twitter"] = pdf["links"].apply(lambda ls: any(l.get("type")=="twitter" for l in ls))
    pdf["has_website"] = pdf["links"].apply(lambda ls: any(l.get("label")=="Website" for l in ls))
    pdf["has_desc"]    = pdf["description"].str.strip().astype(bool)
    print(pdf[["chain_id","token_address","has_twitter","has_website","has_desc","fetched_at"]].head(20))
    return pdf

pdf = to_pandas()
