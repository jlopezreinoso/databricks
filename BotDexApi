# Celda 6: Funciones de análisis

def fetch_tokens() -> list:
    headers = {"Accept": "*/*"}
    resp = requests.get(API_URL, headers=headers, timeout=15)
    resp.raise_for_status()
    data = resp.json()
    return data if isinstance(data, list) else []


def filter_new(tokens: list, existing: set) -> list:
    result = []
    for t in tokens:
        addr = t.get("tokenAddress")
        if not addr or addr in existing:
            continue
        chain = t.get("chainId", "")
        if CHAIN_FILTER and chain not in CHAIN_FILTER:
            continue
        result.append(t)
    return result


def check_keywords(tokens: list) -> list:
    hits = []
    now = datetime.utcnow()
    for t in tokens:
        desc  = (t.get("description") or "").lower()
        addr  = (t.get("tokenAddress") or "").lower()
        links = t.get("links") or []
        link_text = " ".join((l.get("url","") + " " + l.get("label","")) for l in links).lower()
        full_text = desc + " " + addr + " " + link_text
        for kw in KEYWORDS:
            if kw.lower() in full_text:
                hits.append({
                    "token_address": t.get("tokenAddress"),
                    "chain_id":      t.get("chainId"),
                    "keyword":       kw,
                    "description":   (t.get("description") or "")[:300],
                    "url":           t.get("url"),
                    "alerted_at":    now,
                })
    return hits


def chain_stats(tokens: list) -> dict:
    stats = {}
    for t in tokens:
        c = t.get("chainId", "unknown")
        stats[c] = stats.get(c, 0) + 1
    return dict(sorted(stats.items(), key=lambda x: -x[1]))


