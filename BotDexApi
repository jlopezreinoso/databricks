# Celda 7: Loop principal

def run_bot():
    print("=" * 60)
    print("  DEXSCREENER BOT v2 - INICIANDO")
    print("=" * 60)
    print(f"  Keywords : {KEYWORDS}")
    print(f"  Cadenas  : {CHAIN_FILTER or 'Todas'}")
    print(f"  Intervalo: {POLL_INTERVAL}s")
    print(f"  Storage  : {'Unity Catalog' if USE_UNITY_CATALOG else 'Volumes'}")
    print("=" * 60)
    print("\nInicializando tablas Delta...")
    init_tables()

    cycle = 0
    total_seen = 0

    try:
        while True:
            if MAX_CYCLES and cycle >= MAX_CYCLES:
                print(f"\nCiclos completados: {MAX_CYCLES}. Bot detenido.")
                break

            cycle += 1
            print(f"\n[{datetime.now().strftime('%H:%M:%S')}] Ciclo #{cycle}...")

            try:
                raw = fetch_tokens()
                existing = get_existing_addresses()
                new_tokens = filter_new(raw, existing)
                alerts = check_keywords(new_tokens)

                save_tokens(new_tokens)
                save_alerts(alerts)

                total_seen += len(new_tokens)
                display_summary(cycle, new_tokens, alerts, total_seen, len(raw))

            except requests.exceptions.RequestException as e:
                print(f"  ERROR red: {e}")
            except Exception as e:
                import traceback
                print(f"  ERROR: {e}")
                traceback.print_exc()

            if MAX_CYCLES and cycle >= MAX_CYCLES:
                break

            print(f"  Esperando {POLL_INTERVAL}s... (Stop para detener)")
            time.sleep(POLL_INTERVAL)

    except KeyboardInterrupt:
        print("\nBot detenido manualmente.")

    print(f"\nFin: {total_seen} tokens nuevos en {cycle} ciclos.")


run_bot()

