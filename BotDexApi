# Celda 3: CONFIGURACIÓN - Edita aquí

# ---- Palabras clave para alertas ----
KEYWORDS = ["moon", "ai", "pump", "pepe", "meme", "elon", "nasa", "inu", "doge", "trump"]

# ---- Filtrar cadenas ([] = todas) ----
CHAIN_FILTER = []  # Ej: ["solana", "base", "ethereum", "monad"]

# ---- Intervalo entre llamadas (segundos) ----
POLL_INTERVAL = 30

# ---- Ciclos máximos (None = corre hasta Stop) ----
MAX_CYCLES = None

# ---- RUTA DE ALMACENAMIENTO ----
# Opción A: Unity Catalog (recomendado si tienes UC habilitado)
USE_UNITY_CATALOG = False  # Usa Volumes path definido abajo
UC_CATALOG   = "main"
UC_SCHEMA    = "dexscreener"
UC_TABLE_TOKENS = f"{UC_CATALOG}.{UC_SCHEMA}.tokens"
UC_TABLE_ALERTS = f"{UC_CATALOG}.{UC_SCHEMA}.alerts"

# Opción B: Unity Catalog Volumes (tu ruta configurada)
VOL_TOKENS = "/Volumes/ctlfinanciero/schgold/vol_ddfinanciero_model/Objetos/dexscreener_tokens"
VOL_ALERTS = "/Volumes/ctlfinanciero/schgold/vol_ddfinanciero_model/Objetos/dexscreener_alerts"

# ---- API ----
API_URL = "https://api.dexscreener.com/token-profiles/latest/v1"

# =============================================================================
# COMMAND ----------
# Celda 4: Schema (basado en la API real)

LINK_SCHEMA = StructType([
    StructField("type",  StringType(), True),
    StructField("label", StringType(), True),
    StructField("url",   StringType(), True),
])

TOKEN_SCHEMA = StructType([
    StructField("token_address", StringType(),  True),
    StructField("chain_id",      StringType(),  True),
    StructField("url",           StringType(),  True),
    StructField("icon",          StringType(),  True),
    StructField("header",        StringType(),  True),
    StructField("description",   StringType(),  True),
    StructField("links_json",    StringType(),  True),   # JSON string
    StructField("cto",           BooleanType(), True),
    StructField("updated_at",    StringType(),  True),   # ISO string original
    StructField("fetched_at",    TimestampType(), True),
])

ALERT_SCHEMA = StructType([
    StructField("token_address", StringType(),  True),
    StructField("chain_id",      StringType(),  True),
    StructField("keyword",       StringType(),  True),
    StructField("description",   StringType(),  True),
    StructField("url",           StringType(),  True),
    StructField("alerted_at",    TimestampType(), True),
])

# =============================================================================
# COMMAND ----------
# Celda 5: Funciones de almacenamiento

def get_paths():
    """Retorna (tokens_path, alerts_path) según configuración."""
    if USE_UNITY_CATALOG:
        return UC_TABLE_TOKENS, UC_TABLE_ALERTS
    return VOL_TOKENS, VOL_ALERTS


def init_tables():
    """Crea tablas Delta vacías si no existen."""
    tok_path, alt_path = get_paths()
    try:
        if USE_UNITY_CATALOG:
            spark.sql(f"CREATE SCHEMA IF NOT EXISTS {UC_CATALOG}.{UC_SCHEMA}")
            spark.createDataFrame([], TOKEN_SCHEMA).write \
                .format("delta").mode("ignore") \
                .saveAsTable(UC_TABLE_TOKENS)
            spark.createDataFrame([], ALERT_SCHEMA).write \
                .format("delta").mode("ignore") \
                .saveAsTable(UC_TABLE_ALERTS)
        else:
            spark.createDataFrame([], TOKEN_SCHEMA).write \
                .format("delta").mode("ignore").save(tok_path)
            spark.createDataFrame([], ALERT_SCHEMA).write \
                .format("delta").mode("ignore").save(alt_path)
        print(f"  OK Tokens  -> {tok_path}")
        print(f"  OK Alertas -> {alt_path}")
    except Exception as e:
        print(f"  ADVERTENCIA init_tables: {e}")


def get_existing_addresses():
    """Retorna set de token_address ya guardados."""
    tok_path, _ = get_paths()
    try:
        if USE_UNITY_CATALOG:
            df = spark.table(UC_TABLE_TOKENS)
        else:
            df = spark.read.format("delta").load(tok_path)
        return set(df.select("token_address").rdd.flatMap(lambda x: x).collect())
    except Exception:
        return set()


def save_tokens(tokens: list):
    tok_path, _ = get_paths()
    if not tokens:
        return
    now = datetime.utcnow()
    rows = [{
        "token_address": t.get("tokenAddress"),
        "chain_id":      t.get("chainId"),
        "url":           t.get("url"),
        "icon":          t.get("icon"),
        "header":        t.get("header"),
        "description":   (t.get("description") or "").strip(),
        "links_json":    json.dumps(t.get("links") or []),
        "cto":           bool(t.get("cto", False)),
        "updated_at":    t.get("updatedAt", ""),
        "fetched_at":    now,
    } for t in tokens]
    df = spark.createDataFrame(rows, TOKEN_SCHEMA)
    if USE_UNITY_CATALOG:
        df.write.format("delta").mode("append").saveAsTable(UC_TABLE_TOKENS)
    else:
        df.write.format("delta").mode("append").save(tok_path)


def save_alerts(alerts: list):
    _, alt_path = get_paths()
    if not alerts:
        return
    df = spark.createDataFrame(alerts, ALERT_SCHEMA)
    if USE_UNITY_CATALOG:
        df.write.format("delta").mode("append").saveAsTable(UC_TABLE_ALERTS)
    else:
        df.write.format("delta").mode("append").save(alt_path)

