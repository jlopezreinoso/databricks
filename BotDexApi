def query_tokens(limit=50, chain=None):
    tok_path, _ = get_paths()
    if USE_UNITY_CATALOG:
        df = spark.table(UC_TABLE_TOKENS)
    else:
        df = spark.read.format("delta").load(tok_path)
    if chain:
        df = df.filter(col("chain_id") == chain)
    print(f"Total tokens: {df.count()}")
    df.select("chain_id","token_address","description","cto","updated_at","fetched_at") \
      .orderBy(col("fetched_at").desc()) \
      .show(limit, truncate=60)

query_tokens()

